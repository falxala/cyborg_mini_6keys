@echo off
powershell -NoProfile -ExecutionPolicy Bypass -Command "$ports=@([System.IO.Ports.SerialPort]::GetPortNames()|Sort-Object); if($ports.Count -eq 0){Write-Host 'No COM ports found'; pause; exit}; $port=$null; foreach($candidate in $ports){try{$p=New-Object System.IO.Ports.SerialPort($candidate,115200,'None',8,'One'); $p.NewLine='`n'; $p.ReadTimeout=250; $p.WriteTimeout=250; $p.Open(); Start-Sleep -Milliseconds 120; while($p.BytesToRead -gt 0){try{$null=$p.ReadLine()}catch{break}}; $p.WriteLine('probe'); Start-Sleep -Milliseconds 120; $lines=@(); while($p.BytesToRead -gt 0){try{$lines+=$p.ReadLine()}catch{break}}; if(($lines -join ' ') -match 'CYBORG8 ACK'){$port=$candidate; $p.Close(); break}; $p.Close()}catch{if($p -and $p.IsOpen){$p.Close()}}}; if(-not $port){for($i=0;$i -lt $ports.Count;$i++){Write-Host ('[{0}] {1}' -f ($i+1),$ports[$i])}; $n=[int](Read-Host 'Port number'); $port=$ports[$n-1]}; $s=New-Object System.IO.Ports.SerialPort($port,115200,'None',8,'One'); $s.NewLine='`n'; $s.ReadTimeout=200; $s.Open(); Write-Host ('Connected to {0}' -f $port); Write-Host 'Type help or exit'; while($s.BytesToRead -gt 0){try{Write-Host $s.ReadLine()}catch{break}}; while($true){$cmd=Read-Host 'cyborg'; if($cmd -eq 'exit'){break}; $s.WriteLine($cmd); Start-Sleep -Milliseconds 120; while($s.BytesToRead -gt 0){try{Write-Host $s.ReadLine()}catch{break}}}; $s.Close()"
