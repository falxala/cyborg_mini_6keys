@echo off
pushd "%~dp0" >nul 2>&1
powershell -NoProfile -ExecutionPolicy Bypass -Command "$ports=@([System.IO.Ports.SerialPort]::GetPortNames()|Sort-Object); if($ports.Count -eq 0){Write-Host 'No COM ports found'; pause; exit}; $port=$null; $devices=@(Get-CimInstance Win32_PnPEntity | Where-Object { $_.Name -match '\(COM[0-9]+\)' }); foreach($device in $devices){if($device.PNPDeviceID -match 'VID_CAFE.*PID_C608' -or $device.PNPDeviceID -match 'VID_239A.*PID_CAFE' -or $device.Name -match 'Cyborg'){if($device.Name -match '\((COM[0-9]+)\)'){$port=$Matches[1]; Write-Host ('Detected {0}: {1}' -f $port,$device.Name); break}}}; if(-not $port){foreach($candidate in $ports){$candidateDevice=$null; foreach($device in $devices){if($device.Name -match ('\('+$candidate+'\)')){$candidateDevice=$device; break}}; if($candidateDevice -and $candidateDevice.PNPDeviceID -notmatch '^USB\\'){Write-Host ('Skipping {0}: {1}' -f $candidate,$candidateDevice.Name); continue}; Write-Host ('Checking {0}...' -f $candidate); try{$p=New-Object System.IO.Ports.SerialPort($candidate,115200,'None',8,'One'); $p.NewLine='`n'; $p.ReadTimeout=80; $p.WriteTimeout=350; $p.DtrEnable=$true; $p.RtsEnable=$true; $p.Open(); Start-Sleep -Milliseconds 1500; $p.WriteLine('probe'); Start-Sleep -Milliseconds 250; $p.WriteLine('probe'); $deadline=(Get-Date).AddMilliseconds(1800); $lines=@(); while((Get-Date) -lt $deadline){try{$line=$p.ReadLine(); $lines+=$line; if($line -match 'CYBORG8 ACK'){$port=$candidate; break}}catch{Start-Sleep -Milliseconds 40}}; if($lines.Count -gt 0){Write-Host (($lines|Select-Object -Last 3) -join ' | ')}; $p.Close(); if($port){break}}catch{Write-Host ('  skip: {0}' -f $_.Exception.Message); if($p -and $p.IsOpen){$p.Close()}}}}; if(-not $port){Write-Host 'Auto-detect failed. Select a COM port.'; for($i=0;$i -lt $ports.Count;$i++){$name=''; $id=''; foreach($device in $devices){if($device.Name -match ('\('+$ports[$i]+'\)')){$name=$device.Name; $id=$device.PNPDeviceID; break}}; if($name){Write-Host ('[{0}] {1} - {2}' -f ($i+1),$ports[$i],$name); Write-Host ('    {0}' -f $id)}else{Write-Host ('[{0}] {1}' -f ($i+1),$ports[$i])}}; $n=[int](Read-Host 'Port number'); $port=$ports[$n-1]}; $s=New-Object System.IO.Ports.SerialPort($port,115200,'None',8,'One'); $s.NewLine='`n'; $s.ReadTimeout=250; $s.WriteTimeout=500; $s.DtrEnable=$true; $s.RtsEnable=$true; $s.Open(); Write-Host ('Connected to {0}' -f $port); $s.WriteLine('probe'); Start-Sleep -Milliseconds 250; while($s.BytesToRead -gt 0){try{Write-Host $s.ReadLine()}catch{break}}; Write-Host 'Type help or exit'; while($true){$cmd=Read-Host 'cyborg'; if($cmd -eq 'exit'){break}; $s.WriteLine($cmd); Start-Sleep -Milliseconds 120; while($s.BytesToRead -gt 0){try{Write-Host $s.ReadLine()}catch{break}}}; $s.Close()"
popd >nul 2>&1
